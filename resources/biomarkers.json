        "\\bTMB\\b\\s*[:=]?\\s*(\\d+(?:[\\.,]\\d+)?)",
        "мутационн\\w*\\s+нагрузк\\w*\\s*[:=]?\\s*(\\d+(?:[\\.,]\\d+)?)"
      ],
      "unit_hints": [
        "mut/Mb",
        "mut/mb",
        "мутац/мб"
      ]
    },
    {
      "canon": "ER",
      "std": "er",
