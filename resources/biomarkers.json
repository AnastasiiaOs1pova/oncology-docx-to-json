        ]
      },
      "normalize_map": {
        "positive": "dMMR",
        "negative": "не выявлено"
      }
    },
    {
      "canon": "pMMR",
      "std": "pmmr",
      "group": "immuno",
      "patterns": [
        "\\bpMMR\\b",
        "proficient\\s+MMR"
      ],
      "value_type": "status",
      "status_lexicon": {
        "positive": [
          "\\bpMMR\\b",
          "proficient",
          "сохран"
        ],
        "negative": [
          "\\bdMMR\\b",
