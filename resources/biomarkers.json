{
  "version": "2.0",
  "schema": "biomarkers.catalog",
  "notes": "Расширенный каталог биомаркеров для извлечения из ИБ после normalize_med_text. Добавлены типы значений, правила извлечения и нормализации (чтобы не превращать статусы в числа, напр. BRCA1/2=2).",
  "value_types": {
    "none": "Значение не извлекаем (фиксируем только факт упоминания).",
    "numeric": "Число (в т.ч. с десятичной точкой/запятой).",
    "percent": "Проценты (0–100%, допускается пробел перед %).",
    "ihc_score": "ИГХ-оценка 0/1+/2+/3+ или эквиваленты (negative/positive).",
    "status": "Категориальный статус (не обнаружено/обнаружено/положительный/отрицательный/WT/мутация и т.п.).",
    "variant": "Конкретный вариант/мутация/фьюжн (L858R, exon 19 del, V600E, fusion, rearrangement…).",
    "text": "Короткий текст рядом (до 40–60 символов) — когда формальный парсер значения невозможен."
  },
  "biomarkers": [
    {
      "canon": "PD-L1",
      "std": "pd-l1",
      "group": "immuno",
      "patterns": [
        "\\bPD\\s*[- ]?\\s*L\\s*[- ]?\\s*1\\b",
        "\\bПД\\s*[- ]?\\s*Л\\s*[- ]?\\s*1\\b"
      ],
      "value_type": "none",
      "value_hints": [
        "CPS",
        "TPS",
        "%"
      ],
      "comment": "Сам PD-L1 без CPS/TPS часто не имеет явного числа; числа ловятся отдельными маркерами CPS/TPS."
    },
    {
      "canon": "CPS",
      "std": "cps",
      "group": "immuno",
      "patterns": [
        "\\bCPS\\b",
        "combined\\s+positive\\s+score"
      ],
      "value_type": "numeric",
      "value_regexes": [
        "\\bCPS\\b\\s*[:=]?\\s*(\\d{1,3})",
        "\\bCPS\\s*=\\s*(\\d{1,3})"
      ],
      "normalize": {
        "strip": true
      }
    },
    {
      "canon": "TPS",
      "std": "tps",
      "group": "immuno",
      "patterns": [
        "\\bTPS\\b",
        "tumou?r\\s+proportion\\s+score"
      ],
      "value_type": "percent",
      "value_regexes": [
        "\\bTPS\\b\\s*[:=]?\\s*(\\d{1,3})\\s*%?",
        "\\bTPS\\s*=\\s*(\\d{1,3})\\s*%?"
      ]
    },
    {
      "canon": "MSI",
      "std": "msi",
      "group": "immuno",
      "patterns": [
        "\\bMSI\\b",
        "\\bMSI\\s*[- ]?\\s*H\\b",
        "\\bMSI\\s*[- ]?\\s*L\\b",
        "\\bМСИ\\b",
        "\\bМСИ\\s*[- ]?\\s*Н\\b",
        "microsatellite\\s+instabil"
      ],
      "value_type": "status",
      "status_lexicon": {
        "positive": [
          "MSI\\s*[- ]?\\s*H",
          "МСИ\\s*[- ]?\\s*Н",
          "высок",
          "high"
        ],
        "negative": [
          "не\\s+обнаруж",
          "отсутств",
          "stable",
          "stabil",
          "MSS"
        ],
        "unknown": [
          "не\\s+оцен",
          "н/о",
          "нет\\s+данных"
        ]
      },
      "normalize_map": {
        "positive": "MSI-H",
        "negative": "не обнаружено",
        "unknown": "не указано"
      }
    },
    {
      "canon": "MSS",
      "std": "mss",
      "group": "immuno",
      "patterns": [
        "\\bMSS\\b",
        "микросателлитн\\w*\\s+стабил",
        "microsatellite\\s+stable"
      ],
      "value_type": "status",
      "status_lexicon": {
        "positive": [
          "\\bMSS\\b",
          "стабил",
          "stable"
        ],
        "unknown": [
          "не\\s+оцен",
          "н/о"
        ]
      },
      "normalize_map": {
        "positive": "MSS",
        "unknown": "не указано"
      }
    },
    {
