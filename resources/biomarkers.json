        "\\bER\\b",
        "\\bЭР\\b",
        "рецептор(ы)?\\s+эстроген"
      ],
      "value_type": "percent",
      "value_regexes": [
        "\\bER\\b[^0-9]{0,25}(\\d{1,3})\\s*%?",
        "\\bЭР\\b[^0-9]{0,25}(\\d{1,3})\\s*%?"
